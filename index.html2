<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FF Rare ID Zone</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
scroll-behavior:smooth;
}

body{
background:#040816;
color:white;
overflow-x:hidden;
}

/* SCROLLBAR */

::-webkit-scrollbar{
width:8px;
}

::-webkit-scrollbar-thumb{
background:#00eeff;
border-radius:10px;
}

/* NAVBAR */

nav{
position:fixed;
top:0;
left:0;
width:100%;
padding:18px 7%;
display:flex;
justify-content:space-between;
align-items:center;
background:rgba(0,0,0,.5);
backdrop-filter:blur(10px);
z-index:999;
border-bottom:1px solid #00eeff33;
}

.logo{
font-size:30px;
font-weight:900;
color:#00eeff;
text-shadow:0 0 20px #00eeff;
}

nav ul{
display:flex;
gap:25px;
list-style:none;
}

nav ul li a{
text-decoration:none;
color:white;
font-weight:600;
transition:.3s;
}

nav ul li a:hover{
color:#00eeff;
}

/* HERO */

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
background:
linear-gradient(rgba(0,0,0,.7),rgba(0,0,0,.7)),
url('https://wallpapercave.com/wp/wp5128415.jpg');
background-size:cover;
background-position:center;
position:relative;
overflow:hidden;
}

.hero::before{
content:'';
position:absolute;
width:600px;
height:600px;
background:#00eeff22;
filter:blur(100px);
border-radius:50%;
animation:move 6s infinite alternate;
}

@keyframes move{
from{
transform:translate(-150px,-100px);
}
to{
transform:translate(150px,100px);
}
}

.hero-content{
position:relative;
z-index:2;
}

.hero h1{
font-size:75px;
font-weight:900;
color:#00eeff;
text-shadow:0 0 30px #00eeff;
}

.hero p{
margin-top:15px;
font-size:22px;
color:#ddd;
}

.hero-buttons{
margin-top:30px;
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.btn{
padding:15px 35px;
border-radius:15px;
text-decoration:none;
font-weight:800;
transition:.3s;
display:inline-block;
}

.primary-btn{
background:#00eeff;
color:#000;
box-shadow:0 0 25px #00eeff;
}

.primary-btn:hover{
transform:scale(1.08);
}

.secondary-btn{
border:2px solid #00eeff;
color:#00eeff;
}

.secondary-btn:hover{
background:#00eeff;
color:#000;
}

/* LIVE POPUP */

.live-popup{
position:fixed;
bottom:20px;
left:20px;
background:#091226;
padding:15px 20px;
border-radius:15px;
border:1px solid #00eeff55;
box-shadow:0 0 20px #00eeff33;
z-index:999;
animation:popup 2s infinite alternate;
}

@keyframes popup{
from{
transform:translateY(0);
}
to{
transform:translateY(-8px);
}
}

/* SECTION */

.section-title{
text-align:center;
font-size:45px;
margin-bottom:40px;
color:#00eeff;
text-shadow:0 0 15px #00eeff;
}

/* OFFER */

.offer{
padding:100px 8%;
}

.offer-box{
max-width:750px;
margin:auto;
background:#091226;
padding:40px;
border-radius:25px;
text-align:center;
position:relative;
border:2px solid #00eeff55;
box-shadow:0 0 30px #00eeff22;
overflow:hidden;
}

.tag{
position:absolute;
top:20px;
right:-40px;
background:#00eeff;
color:#000;
padding:10px 50px;
font-weight:900;
transform:rotate(45deg);
}

.offer-box h2{
font-size:48px;
margin-top:20px;
}

.offer-box .lvl{
margin-top:10px;
font-size:28px;
color:#00eeff;
font-weight:700;
}

.features{
margin-top:20px;
line-height:2;
font-size:18px;
color:#ddd;
}

.price{
margin-top:20px;
}

.old{
text-decoration:line-through;
font-size:28px;
color:#aaa;
margin-right:10px;
}

.new{
font-size:55px;
font-weight:900;
color:#00ff99;
text-shadow:0 0 20px #00ff99;
}

.discount{
margin-top:15px;
font-size:28px;
font-weight:900;
color:#ffcc00;
}

.timer{
margin-top:15px;
font-size:22px;
color:#ff5555;
font-weight:800;
}

/* SLIDER */

.slider{
padding:70px 0;
overflow:hidden;
white-space:nowrap;
background:#091226;
margin-top:50px;
}

.slide-track{
display:inline-block;
animation:slide 20s linear infinite;
}

.slide{
display:inline-block;
margin:0 20px;
padding:15px 35px;
background:#00eeff22;
border:1px solid #00eeff55;
border-radius:15px;
font-weight:700;
}

@keyframes slide{
0%{
transform:translateX(0);
}
100%{
transform:translateX(-50%);
}
}

/* CARDS */

.cards{
padding:100px 8%;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:30px;
}

.card{
background:#091226;
border-radius:25px;
overflow:hidden;
transition:.3s;
border:1px solid #00eeff22;
position:relative;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 30px #00eeff44;
}

.card img{
width:100%;
height:220px;
object-fit:cover;
}

.card-content{
padding:20px;
}

.card-content h3{
font-size:24px;
margin-bottom:10px;
color:#00eeff;
}

.card-content p{
line-height:1.8;
color:#ddd;
}

.card-price{
margin-top:15px;
font-size:38px;
font-weight:900;
color:#00ff99;
}

.buy-btn{
display:inline-block;
margin-top:18px;
padding:13px 28px;
background:#00eeff;
color:#000;
font-weight:800;
border-radius:12px;
text-decoration:none;
box-shadow:0 0 20px #00eeff;
transition:.3s;
}

.buy-btn:hover{
transform:scale(1.05);
}

/* LOGIN */

.login{
padding:100px 8%;
text-align:center;
}

.login-box{
max-width:500px;
margin:auto;
background:#091226;
padding:40px;
border-radius:25px;
border:1px solid #00eeff44;
}

.login-box input{
width:100%;
padding:15px;
margin:12px 0;
border:none;
outline:none;
border-radius:12px;
background:#101a33;
color:white;
}

.login-box button{
width:100%;
padding:15px;
background:#00eeff;
border:none;
font-weight:800;
border-radius:12px;
cursor:pointer;
}

/* FOOTER */

footer{
padding:50px;
text-align:center;
background:#030712;
border-top:1px solid #00eeff22;
}

footer h2{
color:#00eeff;
margin-bottom:10px;
}

footer p{
margin-top:8px;
color:#ccc;
}

/* MOBILE */

@media(max-width:768px){

.hero h1{
font-size:45px;
}

.hero p{
font-size:18px;
}

.section-title{
font-size:34px;
}

.offer-box h2{
font-size:34px;
}

.new{
font-size:42px;
}

nav ul{
display:none;
}

}

</style>
</head>

<body>

